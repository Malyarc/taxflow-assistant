# Copy this file to `.env` and fill in your values. NEVER commit .env.

# ── Required ──────────────────────────────────────────────────────────
# Postgres connection string (any provider works: RDS, Neon, Supabase, local)
DATABASE_URL=postgres://user:password@localhost:5432/taxflow_pro

# ── AI W-2 extraction (optional but recommended) ──────────────────────
# Get a free Google AI Studio key at https://aistudio.google.com/
# 1,500 requests/day free on gemini-2.0-flash. Vision-capable.
AI_API_KEY=your-google-ai-studio-key

# Override these only if you want to use a different OpenAI-compatible provider
# (e.g. OpenAI, Groq, OpenRouter, local Ollama).
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# AI_MODEL=gemini-2.5-flash

# ── Server ─────────────────────────────────────────────────────────────
# PORT defaults to 8080 if unset.
# PORT=8080

# When set, Express serves the React build from this directory.
# Defaults to ../tax-app/dist/public (set automatically by the build script).
# STATIC_DIR=/var/www/taxflow-pro/public
